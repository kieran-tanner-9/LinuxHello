        def start_preview(self):
            self.preview_thread = CameraThread(self.dev_path)
            self.preview_thread.change_pixmap_signal.connect(self.update_preview)
            self.preview_thread.start()
            
            self.countdown_timer = QtCore.QTimer(self)
            self.countdown_timer.timeout.connect(self.tick_countdown)
            self.countdown_timer.start(1000)
            
        def update_preview(self, qimage):
            p = QtGui.QPixmap.fromImage(qimage).scaled(320, 240, QtCore.Qt.AspectRatioMode.KeepAspectRatio)
            self.lbl_cam_preview.setPixmap(p)
            
        def tick_countdown(self):
            self.countdown -= 1
            if self.countdown > 0:
                self.lbl_status.setText(f"Adjust your position. Scanning in {self.countdown} seconds...")
            else:
                self.countdown_timer.stop()
                self.lbl_status.setText("Capturing face signature... Please look straight at the camera.")
                
                # Stop camera thread to release hardware lock so Howdy can open it
                if self.preview_thread:
                    self.preview_thread.stop()
                    self.preview_thread = None
                    
                self.lbl_cam_preview.setText("Scanning active...")
                self.lbl_cam_preview.setPixmap(QtGui.QPixmap())
                
                self.start_enrollment()
                
        def start_enrollment(self):
            import pwd
            self.progress_bar.setRange(0, 0) # Indeterminate marquee mode while Howdy captures
            self.process = QtCore.QProcess(self)
            self.process.readyReadStandardOutput.connect(self.handle_stdout)
            self.process.readyReadStandardError.connect(self.handle_stderr)
            self.process.finished.connect(self.handle_finished)
            
            try:
                curr_user = os.environ.get("USER") or pwd.getpwuid(os.getuid()).pw_name
            except Exception:
                curr_user = "default"
                
            script_path = os.path.abspath(sys.argv[0])
            self.process.start("pkexec", [script_path, "enroll-and-verify", curr_user, self.label])
            
        def handle_stdout(self):
            try:
                data = self.process.readAllStandardOutput().data().decode("utf-8", errors="ignore")
                for line in data.splitlines():
                    line = line.strip()
                    if not line:
                        continue
                    
                    print(f"[Howdy stdout] {line}")
                    
                    if "look straight into the camera" in line.lower() or "look directly at the camera" in line.lower():
                        self.lbl_status.setText("Camera Active: Look straight into the camera!")
                        self.lbl_status.setStyleSheet("color: #a6e3a1; font-weight: bold; font-size: 14px;")
                    elif "scan complete" in line.lower() or "added new model" in line.lower() or "completed" in line.lower() or "added a new model" in line.lower():
                        self.lbl_status.setText("Success! Face model enrolled.")
                        self.lbl_status.setStyleSheet("color: #a6e3a1; font-weight: bold;")
            except Exception:
                pass
                
        def handle_stderr(self):
            try:
                data = self.process.readAllStandardError().data().decode("utf-8", errors="ignore")
                for line in data.splitlines():
                    line = line.strip()
                    if line:
                        print(f"[Howdy stderr] {line}")
            except Exception:
                pass
            
        def handle_finished(self, exit_code, exit_status):
            self.btn_done.setText("Close")
            self.progress_bar.setRange(0, 100)
            if exit_code == 0:
                self.progress_bar.setValue(100)
                self.lbl_status.setText("Face enrollment completed successfully!")
                self.lbl_status.setStyleSheet("color: #a6e3a1; font-weight: bold; font-size: 13px;")
            elif exit_code == 10:
                self.progress_bar.setValue(0)
                self.lbl_status.setText("Security Alert: Face did not match the owner of this profile. Signature rejected!")
                self.lbl_status.setStyleSheet("color: #f38ba8; font-weight: bold; font-size: 13px;")
            else:
                self.progress_bar.setValue(0)
                self.lbl_status.setText("Face enrollment failed or was cancelled.")
                self.lbl_status.setStyleSheet("color: #f38ba8; font-weight: bold; font-size: 13px;")
                
        def on_button_clicked(self):
            if self.countdown_timer:
                self.countdown_timer.stop()
            if self.preview_thread:
                self.preview_thread.stop()
            if self.process and self.process.state() == QtCore.QProcess.ProcessState.Running:
                self.process.kill()
            self.accept()
            
        def reject(self):
            if self.countdown_timer:
                self.countdown_timer.stop()
            if self.preview_thread:
                self.preview_thread.stop()
            if self.process and self.process.state() == QtCore.QProcess.ProcessState.Running:
                self.process.kill()
            super().reject()

