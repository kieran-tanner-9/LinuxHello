#!/usr/bin/env python3
import os
import sys
import subprocess
import re
import shutil
import time

# Color definitions for terminal output
RED = "\033[91m"
GREEN = "\033[92m"
YELLOW = "\033[93m"
BLUE = "\033[94m"
MAGENTA = "\033[95m"
CYAN = "\033[96m"
BOLD = "\033[1m"
RESET = "\033[0m"

def check_root():
    """Verify script is run with root/sudo permissions."""
    if os.geteuid() != 0:
        print(f"{RED}{BOLD}Error:{RESET} This command must be run as root. Please run with {BOLD}sudo{RESET}.")
        print(f"Example: {CYAN}sudo {sys.argv[0]} {sys.argv[1] if len(sys.argv) > 1 else 'status'}{RESET}")
        sys.exit(1)

def find_howdy_config():
    """Find the howdy config.ini path."""
    paths = [
        "/etc/howdy/config.ini",
        "/lib/security/howdy/config.ini",
        "/usr/share/howdy/config.ini"
    ]
    for p in paths:
        if os.path.exists(p):
            return p
    return "/etc/howdy/config.ini"

def get_installed_packages():
    """Check if howdy and dependencies are installed."""
    howdy_installed = shutil.which("howdy") is not None
    v4l_installed = shutil.which("v4l2-ctl") is not None
    
    opencv_installed = False
    try:
        import cv2
        opencv_installed = True
    except ImportError:
        pass
        
    return howdy_installed, v4l_installed, opencv_installed

def get_pam_status():
    """Check if howdy is configured in PAM."""
    pam_file = "/etc/pam.d/common-auth"
    if not os.path.exists(pam_file):
        return False, "PAM file not found"
        
    with open(pam_file, "r") as f:
        content = f.read()
        
    if "pam_howdy.so" in content and not re.search(r"^#.*pam_howdy\.so", content, re.MULTILINE):
        return True, "Enabled globally via common-auth (pam_howdy.so)"
    elif "Howdy.py" in content and not re.search(r"^#.*Howdy\.py", content, re.MULTILINE):
        return True, "Enabled globally via common-auth (Howdy.py)"
    else:
        return False, "Disabled"

def get_enrolled_faces():
    """Get list of enrolled faces."""
    if shutil.which("howdy") is None:
        return []
    user = os.environ.get("SUDO_USER") or os.environ.get("USER") or "default"
    paths = [
        f"/usr/share/dlib/{user}.dat",
        f"/var/lib/howdy/models/{user}.dat",
        f"/etc/howdy/models/{user}.dat",
        f"/lib/security/howdy/models/{user}.dat"
    ]
    model_file = None
    for p in paths:
        if os.path.exists(p):
            model_file = p
            break
            
    if not model_file:
        return []
        
    try:
        import json
        import datetime
        with open(model_file, "r") as f:
            data = json.load(f)
            
        faces = []
        for item in data:
            dt = datetime.datetime.fromtimestamp(item.get("time", 0))
            date_str = dt.strftime("%Y-%m-%d %H:%M:%S")
            faces.append({
                "id": str(item.get("id", 0)),
                "date": date_str,
                "label": item.get("label", "Unknown")
            })
        return faces
    except Exception:
        pass
    return []

def get_cameras():
    """Scan and return all video devices."""
    devices = []
    import glob
    for path in sorted(glob.glob("/sys/class/video4linux/video*")):
        name_file = os.path.join(path, "name")
        if os.path.exists(name_file):
            with open(name_file, "r") as f:
                name = f.read().strip()
            dev_node = "/dev/" + os.path.basename(path)
            devices.append({"device": dev_node, "name": name})
    return devices

def cmd_status():
    """Display system status."""
    print(f"\n{BOLD}{CYAN}=== Linux Hello Configuration Status ==={RESET}\n")
    
    # 1. Package Status
    howdy_inst, v4l_inst, cv_inst = get_installed_packages()
    print(f"{BOLD}Dependencies:{RESET}")
    print(f"  - Howdy package:     {GREEN}Installed{RESET}" if howdy_inst else f"  - Howdy package:     {RED}Not Installed{RESET}")
    print(f"  - v4l-utils (tools): {GREEN}Installed{RESET}" if v4l_inst else f"  - v4l-utils (tools): {RED}Not Installed{RESET}")
    print(f"  - Python OpenCV:     {GREEN}Installed{RESET}" if cv_inst else f"  - Python OpenCV:     {RED}Not Installed{RESET}")
    
    # 2. Camera Status
    cameras = get_cameras()
    print(f"\n{BOLD}Video Devices Detected:{RESET}")
    if not cameras:
        print(f"  {RED}No camera devices detected.{RESET}")
    else:
        for cam in cameras:
            is_ir = "ir" in cam["name"].lower()
            tag = f" {MAGENTA}[IR Camera]{RESET}" if is_ir else ""
            print(f"  - {BOLD}{cam['device']}{RESET}: {cam['name']}{tag}")
            
    # 3. Active Configured Camera in Howdy
    config_path = find_howdy_config()
    configured_device = "Unknown"
    if os.path.exists(config_path):
        with open(config_path, "r") as f:
            for line in f:
                if line.strip().startswith("device_path"):
                    parts = line.split("=")
                    if len(parts) > 1:
                        configured_device = parts[1].split("#")[0].strip()
                        break
        print(f"\n{BOLD}Howdy Configured Camera:{RESET}")
        print(f"  - Current Path: {YELLOW}{configured_device}{RESET} (Config: {config_path})")
    
    # 4. PAM Status
    pam_enabled, pam_desc = get_pam_status()
    print(f"\n{BOLD}PAM Authentication (Login/Sudo):{RESET}")
    print(f"  - Status: " + (f"{GREEN}{BOLD}Enabled{RESET} ({pam_desc})" if pam_enabled else f"{RED}{BOLD}Disabled{RESET}"))
    
    # 5. Enrolled faces
    faces = get_enrolled_faces()
    print(f"\n{BOLD}Enrolled Face Profiles:{RESET}")
    if not faces:
        print(f"  {YELLOW}No faces enrolled yet.{RESET} Run '{CYAN}sudo {sys.argv[0]} enroll{RESET}' to add one.")
    else:
        for face in faces:
            print(f"  - ID: {BOLD}{face['id']}{RESET} | Label: {GREEN}{face['label']}{RESET} | Enrolled: {face['date']}")
            
    print()

def cmd_install():
    """Install howdy and dependencies, and integrate with system launcher."""
    check_root()
    print(f"\n{BOLD}{CYAN}=== Installing Howdy & Dependencies ==={RESET}\n")
    
    # 1. Add PPA
    print(f"{BLUE}[1/5] Adding PPA ppa:ubuntuhandbook1/howdy...{RESET}")
    res = subprocess.run(["add-apt-repository", "-y", "ppa:ubuntuhandbook1/howdy"], check=False)
    if res.returncode != 0:
        print(f"{RED}Failed to add PPA. Please verify internet connection and repository state.{RESET}")
        sys.exit(1)
        
    # 2. Update package list
    print(f"{BLUE}[2/5] Updating package index...{RESET}")
    subprocess.run(["apt-get", "update"], check=True)
    
    # 3. Install packages (including python3-pyqt6)
    print(f"{BLUE}[3/5] Installing howdy, v4l-utils, python3-opencv, python3-pyqt6...{RESET}")
    res = subprocess.run(["apt-get", "install", "-y", "howdy", "v4l-utils", "python3-opencv", "python3-pyqt6"], check=False)
    if res.returncode != 0:
        print(f"{RED}Failed to install packages. Attempting automatic resolution...{RESET}")
        subprocess.run(["apt-get", "install", "-f", "-y"], check=True)
        
    # 4. Copy ourselves to /usr/local/bin
    print(f"{BLUE}[4/5] Copying script to /usr/local/bin/linux-hello...{RESET}")
    try:
        shutil.copy2(sys.argv[0], "/usr/local/bin/linux-hello")
        os.chmod("/usr/local/bin/linux-hello", 0o755)
        print(f"{GREEN}✓ Global executable installed at /usr/local/bin/linux-hello{RESET}")
    except Exception as e:
        print(f"{RED}Failed to copy script: {e}{RESET}")
        sys.exit(1)
        
    # 5. Create desktop launcher entry
    print(f"{BLUE}[5/5] Creating application launcher desktop entry...{RESET}")
    desktop_entry = """[Desktop Entry]
Name=Linux Hello
Comment=Windows Hello Face Authentication for Linux
Exec=/usr/local/bin/linux-hello gui
Icon=preferences-system-security
Terminal=false
Type=Application
Categories=Settings;System;Security;
StartupNotify=true
"""
    try:
        desktop_path = "/usr/share/applications/linux-hello.desktop"
        with open(desktop_path, "w") as f:
            f.write(desktop_entry)
        os.chmod(desktop_path, 0o644)
        print(f"{GREEN}✓ Desktop launcher created at {desktop_path}{RESET}")
    except Exception as e:
        print(f"{RED}Failed to create desktop entry: {e}{RESET}")
        
    print(f"\n{GREEN}{BOLD}✓ Installation & System Integration completed!{RESET}")
    print(f"You can now launch 'Linux Hello' from your desktop application launcher,")
    print(f"or run the GUI directly from terminal: {CYAN}linux-hello gui{RESET}")

def render_ascii(frame):
    """Render frame as grayscale ASCII for terminal preview."""
    import cv2
    h, w = frame.shape[:2]
    # Standard terminal dimensions: target width is 60 columns
    target_w = 60
    # Line height in terminals is roughly double the width of a character, adjust aspect ratio
    target_h = int((h / w) * target_w * 0.45)
    if target_h < 1:
        target_h = 1
        
    resized = cv2.resize(frame, (target_w, target_h))
    if len(resized.shape) == 3:
        gray = cv2.cvtColor(resized, cv2.COLOR_BGR2GRAY)
    else:
        gray = resized
        
    chars = " .:-=+*#%@"
    num_chars = len(chars)
    
    rows = []
    for r in range(target_h):
        row_chars = []
        for c in range(target_w):
            val = gray[r, c]
            char_idx = int((val / 255.0) * (num_chars - 1))
            row_chars.append(chars[char_idx])
        rows.append("".join(row_chars))
    return "\n".join(rows)

def cmd_test_camera(device_path=None):
    """Capture frames from a camera and display them in terminal as ASCII or save a test file."""
    # Ensure OpenCV is installed
    try:
        import cv2
    except ImportError:
        print(f"{RED}Error: OpenCV is not installed. Please run installation command first.{RESET}")
        sys.exit(1)
        
    cameras = get_cameras()
    if not cameras:
        print(f"{RED}Error: No video devices found on this system.{RESET}")
        sys.exit(1)
        
    # If no device specified, prompt user
    if not device_path:
        print(f"\n{BOLD}Select a camera to test:{RESET}")
        for i, cam in enumerate(cameras):
            is_ir = "ir" in cam["name"].lower()
            tag = f" {MAGENTA}[IR Camera]{RESET}" if is_ir else ""
            print(f"  {BOLD}{i+1}){RESET} {cam['device']} ({cam['name']}){tag}")
            
        try:
            choice = input(f"\nEnter camera number (1-{len(cameras)}) [default: 1]: ").strip()
            if not choice:
                idx = 0
            else:
                idx = int(choice) - 1
            if idx < 0 or idx >= len(cameras):
                print(f"{RED}Invalid selection.{RESET}")
                sys.exit(1)
            device_path = cameras[idx]["device"]
        except (ValueError, KeyboardInterrupt, EOFError):
            print(f"\n{RED}Selection cancelled.{RESET}")
            sys.exit(1)
            
    print(f"\nOpening video stream on {BOLD}{device_path}{RESET}...")
    cap = cv2.VideoCapture(device_path)
    if not cap.isOpened():
        print(f"{RED}Error: Could not open video device at {device_path}.{RESET}")
        print("Make sure no other program is using the camera and you have root permissions.")
        sys.exit(1)
        
    print(f"{GREEN}Camera opened successfully.{RESET}")
    print("Press Ctrl+C at any time to exit the test stream.")
    time.sleep(1) # Warm up camera
    
    # Try graphical preview if DISPLAY environment is set
    has_display = os.environ.get("DISPLAY") is not None or os.environ.get("WAYLAND_DISPLAY") is not None
    
    # Clear screen for terminal ASCII art rendering
    print("\033[2J", end="")
    
    try:
        frame_count = 0
        while frame_count < 100:
            ret, frame = cap.read()
            if not ret:
                print(f"\r{RED}Error reading frame from camera.{RESET}", end="")
                time.sleep(0.1)
                continue
                
            # Render to terminal
            ascii_frame = render_ascii(frame)
            print("\033[H", end="")
            print(f"{BOLD}{CYAN}=== ASCII Camera Preview ({device_path}) ==={RESET}")
            print(ascii_frame)
            print(f"\n{YELLOW}Frame: {frame_count}/100. Checking video feed quality.{RESET}")
            print("Move your head to verify that the camera detects your face movement.")
            
            # If graphical display is active, show the OpenCV frame too
            if has_display:
                try:
                    cv2.imshow(f"Linux Hello Test - {device_path}", frame)
                    # waitKey handles GUI event queue, 1ms delay
                    if cv2.waitKey(1) & 0xFF == ord('q'):
                        break
                except Exception:
                    # Ignore graphical errors and stay in CLI mode
                    pass
                    
            frame_count += 1
            time.sleep(0.08) # ~12 FPS
            
    except KeyboardInterrupt:
        print("\nTest stopped by user.")
        
    finally:
        cap.release()
        if has_display:
            try:
                cv2.destroyAllWindows()
            except Exception:
                pass
        print(f"\n{GREEN}Camera test complete.{RESET}")

def cmd_setup_camera():
    """Setup selected camera in howdy config."""
    check_root()
    cameras = get_cameras()
    if not cameras:
        print(f"{RED}Error: No video devices found on this system.{RESET}")
        sys.exit(1)
        
    print(f"\n{BOLD}{CYAN}=== Configure Howdy IR Camera ==={RESET}\n")
    print("Available cameras:")
    for i, cam in enumerate(cameras):
        is_ir = "ir" in cam["name"].lower()
        tag = f" {MAGENTA}[IR Camera - Recommended]{RESET}" if is_ir else ""
        print(f"  {BOLD}{i+1}){RESET} {cam['device']} ({cam['name']}){tag}")
        
    try:
        choice = input(f"\nEnter camera number to use with Howdy (1-{len(cameras)}): ").strip()
        idx = int(choice) - 1
        if idx < 0 or idx >= len(cameras):
            print(f"{RED}Invalid selection.{RESET}")
            sys.exit(1)
        selected_device = cameras[idx]["device"]
    except (ValueError, KeyboardInterrupt, EOFError):
        print(f"\n{RED}Selection cancelled.{RESET}")
        sys.exit(1)
        
    config_path = find_howdy_config()
    if not os.path.exists(config_path):
        print(f"{RED}Error: Howdy config file not found at {config_path}.{RESET}")
        print("Please run install command first: sudo ./linux-hello install")
        sys.exit(1)
        
    # Backup config file
    backup_config = config_path + ".bak"
    shutil.copy2(config_path, backup_config)
    print(f"Backed up howdy config to {backup_config}")
    
    # Update config device path
    with open(config_path, "r") as f:
        lines = f.readlines()
        
    updated = False
    for i, line in enumerate(lines):
        if line.strip().startswith("device_path"):
            parts = line.split("=")
            comment = ""
            if "#" in parts[1]:
                comment = "  #" + parts[1].split("#", 1)[1]
            lines[i] = f"device_path = {selected_device}{comment.rstrip()}\n"
            updated = True
            break
            
    if not updated:
        # If section is [video], insert it
        for i, line in enumerate(lines):
            if "[video]" in line:
                lines.insert(i + 1, f"device_path = {selected_device}\n")
                updated = True
                break
                
    if not updated:
        lines.append(f"\ndevice_path = {selected_device}\n")
        
    with open(config_path, "w") as f:
        f.writelines(lines)
        
    print(f"{GREEN}{BOLD}✓ Camera set to {selected_device} in config!{RESET}")
    print(f"Try running test-camera to confirm: {CYAN}sudo {sys.argv[0]} test-camera {selected_device}{RESET}")
    print(f"Enroll your face next: {CYAN}sudo {sys.argv[0]} enroll{RESET}")

def cmd_enroll():
    """Enroll a new face model."""
    check_root()
    print(f"\n{BOLD}{CYAN}=== Enroll Face Signature ==={RESET}\n")
    print("This will call the Howdy face enrollment assistant.")
    print("Please look directly at the camera when the scan starts.")
    
    # Prompt for a profile name
    try:
        username = os.environ.get("SUDO_USER") or os.environ.get("USER") or "default"
        label = input(f"Enter a label for this face model [default: {username}]: ").strip()
        if not label:
            label = username
    except (KeyboardInterrupt, EOFError):
        print(f"\n{RED}Enrollment cancelled.{RESET}")
        sys.exit(1)
        
    print(f"\nStarting enrollment for label: '{BOLD}{label}{RESET}'...")
    
    # Howdy add requires interaction
    try:
        # We pass label as a command line argument to avoid double labeling prompt
        res = subprocess.run(["howdy", "add", label], check=False)
        if res.returncode == 0:
            print(f"\n{GREEN}{BOLD}✓ Face enrollment complete!{RESET}")
            print(f"Enable authentication next: {CYAN}sudo {sys.argv[0]} enable-pam{RESET}")
        else:
            print(f"\n{RED}Face enrollment failed or was cancelled.{RESET}")
    except Exception as e:
        print(f"\n{RED}Error invoking howdy add: {e}{RESET}")

def cmd_enable_pam():
    """Safely enable face auth globally in PAM."""
    check_root()
    print(f"\n{BOLD}{CYAN}=== Enabling PAM Face Authentication ==={RESET}\n")
    
    # We prioritize using pam-auth-update if the profile exists
    howdy_pam_profile = "/usr/share/pam-configs/howdy"
    
    if os.path.exists(howdy_pam_profile):
        print(f"{BLUE}Found standard pam-auth-update profile.{RESET}")
        print(f"Enabling Howdy PAM profile...{RESET}")
        # Run non-interactive pam-auth-update to enable
        res = subprocess.run(["pam-auth-update", "--package", "--enable", "howdy"], check=False)
        if res.returncode == 0:
            print(f"{GREEN}{BOLD}✓ PAM face authentication enabled successfully!{RESET}")
            return
        else:
            print(f"{YELLOW}pam-auth-update failed. Falling back to manual PAM modification...{RESET}")
            
    # Fallback to manual insertion in /etc/pam.d/common-auth
    pam_file = "/etc/pam.d/common-auth"
    backup_file = pam_file + ".orig"
    
    if not os.path.exists(pam_file):
        print(f"{RED}Error: {pam_file} not found. Cannot configure PAM.{RESET}")
        sys.exit(1)
        
    # Backup original configuration if it doesn't exist
    if not os.path.exists(backup_file):
        shutil.copy2(pam_file, backup_file)
        print(f"Created secure PAM backup at {backup_file}")
        
    with open(pam_file, "r") as f:
        lines = f.readlines()
        
    # Check if already added
    already_exists = False
    for line in lines:
        if "pam_howdy.so" in line and not line.strip().startswith("#"):
            already_exists = True
            break
            
    if already_exists:
        print(f"{GREEN}PAM authentication is already enabled for Howdy.{RESET}")
        return
        
    # Locate pam_unix.so line
    unix_idx = -1
    for i, line in enumerate(lines):
        if "pam_unix.so" in line and not line.strip().startswith("#"):
            unix_idx = i
            break
            
    if unix_idx == -1:
        print(f"{RED}Error: Could not locate pam_unix.so in {pam_file}.{RESET}")
        print("To protect your system from lockout, PAM was not modified.")
        sys.exit(1)
        
    # Insert pam_howdy.so line before pam_unix.so
    # sufficient means: if Howdy succeeds, authorize immediately; if fails, fall back to next lines (pam_unix.so)
    howdy_line = "auth\tsufficient\tpam_howdy.so\n"
    lines.insert(unix_idx, howdy_line)
    
    with open(pam_file, "w") as f:
        f.writelines(lines)
        
    print(f"{GREEN}{BOLD}✓ PAM face authentication enabled successfully!{RESET}")
    print(f"For safety, keep this terminal open and open a NEW terminal window to test '{BOLD}sudo whoami{RESET}'.")

def cmd_disable_pam():
    """Disable face auth in PAM by restoring backup."""
    check_root()
    print(f"\n{BOLD}{CYAN}=== Disabling PAM Face Authentication ==={RESET}\n")
    
    # Try pam-auth-update first
    howdy_pam_profile = "/usr/share/pam-configs/howdy"
    if os.path.exists(howdy_pam_profile):
        print(f"Disabling Howdy PAM profile...{RESET}")
        res = subprocess.run(["pam-auth-update", "--package", "--disable", "howdy"], check=False)
        if res.returncode == 0:
            print(f"{GREEN}{BOLD}✓ Face authentication disabled.{RESET}")
            return
            
    # Try manual restore
    pam_file = "/etc/pam.d/common-auth"
    backup_file = pam_file + ".orig"
    
    restored = False
    if os.path.exists(backup_file):
        shutil.copy2(backup_file, pam_file)
        print(f"Restored original PAM configuration from {backup_file}")
        restored = True
    else:
        # If no backup, manually remove the line
        if os.path.exists(pam_file):
            with open(pam_file, "r") as f:
                lines = f.readlines()
            new_lines = [line for line in lines if "pam_howdy.so" not in line]
            if len(new_lines) != len(lines):
                with open(pam_file, "w") as f:
                    f.writelines(new_lines)
                print("Manually removed pam_howdy.so configuration from common-auth.")
                restored = True
                
    if restored:
        print(f"{GREEN}{BOLD}✓ Face authentication disabled.{RESET}")
    else:
        print(f"{YELLOW}Face authentication was not enabled in PAM.{RESET}")

def cmd_set_priority(devices):
    """Save the list of cameras to priority file."""
    check_root()
    priority_file = "/etc/howdy/camera_priority.conf"
    
    os.makedirs(os.path.dirname(priority_file), exist_ok=True)
    
    with open(priority_file, "w") as f:
        for dev in devices:
            f.write(f"{dev}\n")
            
    print(f"{GREEN}{BOLD}✓ Priority list saved to {priority_file}{RESET}")

def cmd_udev_trigger():
    """Triggered by udev/systemd when video device changes. Updates Howdy config."""
    check_root()
    priority_file = "/etc/howdy/camera_priority.conf"
    if not os.path.exists(priority_file):
        return
        
    with open(priority_file, "r") as f:
        priority_list = [line.strip() for line in f if line.strip()]
        
    connected_cameras = [cam["device"] for cam in get_cameras()]
    
    selected_device = None
    for dev in priority_list:
        if dev in connected_cameras:
            selected_device = dev
            break
            
    if not selected_device:
        if connected_cameras:
            selected_device = connected_cameras[0]
            
    if selected_device:
        config_path = find_howdy_config()
        if os.path.exists(config_path):
            with open(config_path, "r") as f:
                lines = f.readlines()
                
            updated = False
            for i, line in enumerate(lines):
                if line.strip().startswith("device_path"):
                    parts = line.split("=")
                    comment = ""
                    if "#" in parts[1]:
                        comment = "  #" + parts[1].split("#", 1)[1]
                    lines[i] = f"device_path = {selected_device}{comment.rstrip()}\n"
                    updated = True
                    break
                    
            if not updated:
                for i, line in enumerate(lines):
                    if "[video]" in line:
                        lines.insert(i + 1, f"device_path = {selected_device}\n")
                        updated = True
                        break
                        
            if not updated:
                lines.append(f"\ndevice_path = {selected_device}\n")
                
            with open(config_path, "w") as f:
                f.writelines(lines)
            print(f"{GREEN}{BOLD}✓ Switcher: Howdy camera set to {selected_device}{RESET}")

def cmd_enable_switching():
    """Install and enable dynamic camera switching via udev and systemd."""
    check_root()
    print(f"\n{BOLD}{CYAN}=== Enabling Dynamic Camera Switching ==={RESET}\n")
    
    # 1. Create systemd service
    service_content = """[Unit]
Description=Linux Hello Camera Switcher
After=local-fs.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/linux-hello udev-trigger
"""
    service_path = "/etc/systemd/system/linux-hello-switch.service"
