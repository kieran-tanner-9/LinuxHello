def cmd_enroll_and_verify(user, label):
    """Enroll a face signature and verify that it belongs to the profile owner."""
    check_root()
    print(f"\n{BOLD}{CYAN}=== Secure Profile Verification & Enrollment ==={RESET}\n", flush=True)
    
    # Locate model paths
    paths = [
        f"/usr/share/dlib/{user}.dat",
        f"/var/lib/howdy/models/{user}.dat",
        f"/etc/howdy/models/{user}.dat",
        f"/lib/security/howdy/models/{user}.dat"
    ]
    model_file = None
    for p in paths:
        if os.path.exists(p):
            model_file = p
            break
            
    if not model_file:
        for p in paths:
            parent = os.path.dirname(p)
            if os.path.exists(parent):
                model_file = p
                break
        if not model_file:
            model_file = paths[0]
            
    # Load existing vectors
    existing_vectors = []
    existing_ids = set()
    if os.path.exists(model_file):
        try:
            import json
            with open(model_file, "r") as f:
                data = json.load(f)
            for item in data:
                if "data" in item and len(item["data"]) > 0:
                    existing_vectors.append(item["data"][0])
                if "id" in item:
                    existing_ids.add(str(item["id"]))
        except Exception as e:
            print(f"Warning: Failed to load existing face models: {e}", flush=True)

    # Launch howdy add with user option
    print(f"Scanning face for user '{user}' under label '{label}'...", flush=True)
    res = subprocess.run(["howdy", "-U", user, "-y", "add", label], check=False)
    if res.returncode != 0:
        print(f"\n{RED}Error: Howdy enrollment failed with exit code {res.returncode}.{RESET}", flush=True)
        sys.exit(res.returncode)
        
    # Read the models file again to extract the new vector and ID
    if not os.path.exists(model_file):
        print(f"\n{RED}Error: Model file {model_file} not found after scanning.{RESET}", flush=True)
        sys.exit(1)
        
    new_data = []
    try:
        import json
        with open(model_file, "r") as f:
            new_data = json.load(f)
    except Exception as e:
        print(f"\n{RED}Error: Failed to reload models file: {e}{RESET}", flush=True)
        sys.exit(1)
        
    new_item = None
    for item in new_data:
        if "id" in item and str(item["id"]) not in existing_ids:
            new_item = item
            break
            
    if not new_item:
        if len(new_data) > len(existing_vectors):
            new_item = new_data[-1]
            
    if not new_item or "data" not in new_item or len(new_item["data"]) == 0:
        print(f"\n{RED}Error: New face signature was not successfully saved.{RESET}", flush=True)
        sys.exit(1)
        
    new_vector = new_item["data"][0]
    new_id = str(new_item.get("id"))
    
    # Verify against existing vectors if they exist
    if existing_vectors:
        import math
        
        def euclidean_distance(v1, v2):
            return math.sqrt(sum((x - y) ** 2 for x, y in zip(v1, v2)))
            
        distances = [euclidean_distance(new_vector, ev) for ev in existing_vectors]
        min_distance = min(distances)
        print(f"Verification: Minimum Euclidean distance to existing signatures is {min_distance:.4f}", flush=True)
        
        # 0.55 is a safe threshold (matches within same person are < 0.60, different > 0.60)
        if min_distance > 0.55:
            print(f"\n{RED}{BOLD}Security Alert: Scanned face does not match the owner of this profile!{RESET}", flush=True)
            print(f"Euclidean distance {min_distance:.4f} exceeds threshold (0.55).", flush=True)
            print("Removing unverified face signature...", flush=True)
            
            # Remove using howdy
            remove_res = subprocess.run(["howdy", "-U", user, "-y", "remove", new_id], check=False)
            if remove_res.returncode == 0:
                print("Unverified signature successfully removed.", flush=True)
            else:
                print("Warning: Howdy remove failed. Performing manual database cleanup...", flush=True)
                try:
                    updated_data = [item for item in new_data if str(item.get("id")) != new_id]
                    with open(model_file, "w") as f:
                        json.dump(updated_data, f)
                    print("Manual cleanup completed.", flush=True)
                except Exception as ex:
                    print(f"Error: Manual cleanup failed: {ex}", flush=True)
            sys.exit(10) # Custom exit code indicating signature rejection due to mismatch
            
    print(f"\n{GREEN}{BOLD}✓ Face signature verified and enrolled successfully!{RESET}", flush=True)
    sys.exit(0)

