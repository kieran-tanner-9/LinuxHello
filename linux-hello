        def load_camera_list(self):
            self.list_cameras.clear()
            
            priority_list = []
            priority_file = "/etc/howdy/camera_priority.conf"
            if os.path.exists(priority_file):
                try:
                    with open(priority_file, "r") as f:
                        priority_list = [line.strip() for line in f if line.strip()]
                except Exception:
                    pass
                    
            connected = get_cameras()
            connected_devs = [c["device"] for c in connected]
            
            final_list = []
            for dev in priority_list:
                if dev in connected_devs:
                    cam = next(c for c in connected if c["device"] == dev)
                    final_list.append((dev, cam["name"], True))
                    
            for dev in priority_list:
                if dev not in connected_devs:
                    final_list.append((dev, "Disconnected Camera", False))
                    
            for cam in connected:
                dev = cam["device"]
                if dev not in priority_list:
                    final_list.append((dev, cam["name"], True))
                    
            for dev, name, is_conn in final_list:
                is_ir = "ir" in name.lower() or "ir" in dev.lower()
                tag = " [IR]" if is_ir else ""
                status = "" if is_conn else " [Disconnected]"
                item_text = f"{dev} ({name}){tag}{status}"
                
                item = QtWidgets.QListWidgetItem(item_text)
                item.setData(QtCore.Qt.ItemDataRole.UserRole, dev)
                
                if not is_conn:
                    item.setForeground(QtGui.QBrush(QtGui.QColor("#585b70")))
                    item.setFlags(item.flags() & ~QtCore.Qt.ItemFlag.ItemIsEnabled)
                    
                self.list_cameras.addItem(item)
                
            if self.list_cameras.count() > 0:
                self.list_cameras.setCurrentRow(0)

        def update_profiles(self):
            self.list_profiles.clear()
            faces = get_enrolled_faces()
            
            # Group by label
            grouped = {}
            for face in faces:
                lbl = face["label"]
                if lbl not in grouped:
                    grouped[lbl] = []
                grouped[lbl].append(face)
                
            # Populate QListWidget
            for lbl, models in grouped.items():
                count = len(models)
                count_str = f" ({count} signature{'s' if count > 1 else ''})" if count > 1 else ""
                item_text = f"Profile: {lbl}{count_str}"
                
                item = QtWidgets.QListWidgetItem(item_text)
                item.setData(QtCore.Qt.ItemDataRole.UserRole, [m["id"] for m in models]) # List of IDs
                item.setData(QtCore.Qt.ItemDataRole.UserRole + 1, lbl) # Profile label
                self.list_profiles.addItem(item)
                
            if self.list_profiles.count() > 0:
                self.list_profiles.setCurrentRow(0)

        def move_up(self):
            row = self.list_cameras.currentRow()
            if row > 0:
                item = self.list_cameras.takeItem(row)
                self.list_cameras.insertItem(row - 1, item)
                self.list_cameras.setCurrentRow(row - 1)
                
        def move_down(self):
            row = self.list_cameras.currentRow()
            if row < self.list_cameras.count() - 1:
                item = self.list_cameras.takeItem(row)
                self.list_cameras.insertItem(row + 1, item)
                self.list_cameras.setCurrentRow(row + 1)

        def toggle_pam(self):
            pam_enabled, _ = get_pam_status()
            cmd = "disable-pam" if pam_enabled else "enable-pam"
            self.stop_preview()
            res = subprocess.run(["pkexec", "/usr/local/bin/linux-hello", cmd], capture_output=True, text=True)
            if res.returncode == 0:
                self.update_status()
                QtWidgets.QMessageBox.information(self, "Success", f"PAM Face Authentication has been {'disabled' if pam_enabled else 'enabled'}.")
            else:
                QtWidgets.QMessageBox.critical(self, "Error", f"Failed to modify PAM configuration:\n{res.stderr or 'Cancelled by user'}")

        def toggle_switching(self):
            switching_active = os.path.exists("/etc/udev/rules.d/99-linux-hello.rules")
            cmd = "disable-switching" if switching_active else "enable-switching"
            res = subprocess.run(["pkexec", "/usr/local/bin/linux-hello", cmd], capture_output=True, text=True)
            if res.returncode == 0:
                self.update_status()
                QtWidgets.QMessageBox.information(self, "Success", f"Dynamic Camera Switching has been {'disabled' if switching_active else 'enabled'}.")
            else:
                QtWidgets.QMessageBox.critical(self, "Error", f"Failed to modify switching configuration:\n{res.stderr or 'Cancelled by user'}")

        def save_priority(self):
            priority_devices = []
            for i in range(self.list_cameras.count()):
                item = self.list_cameras.item(i)
                priority_devices.append(item.data(QtCore.Qt.ItemDataRole.UserRole))
                
            res = subprocess.run(["pkexec", "/usr/local/bin/linux-hello", "set-priority"] + priority_devices, capture_output=True, text=True)
            if res.returncode == 0:
                QtWidgets.QMessageBox.information(self, "Success", "Camera priority list saved successfully.")
                subprocess.run(["pkexec", "/usr/local/bin/linux-hello", "udev-trigger"], capture_output=True)
            else:
                QtWidgets.QMessageBox.critical(self, "Error", f"Failed to save priority:\n{res.stderr or 'Cancelled by user'}")

        def delete_profile(self):
            item = self.list_profiles.currentItem()
            if not item:
                QtWidgets.QMessageBox.warning(self, "Warning", "Please select a profile to delete.")
                return
                
            face_ids = item.data(QtCore.Qt.ItemDataRole.UserRole)
            lbl = item.data(QtCore.Qt.ItemDataRole.UserRole + 1)
            
            reply = QtWidgets.QMessageBox.question(
                self, "Confirm Delete", f"Are you sure you want to delete profile '{lbl}' and all its associated signatures?",
                QtWidgets.QMessageBox.StandardButton.Yes | QtWidgets.QMessageBox.StandardButton.No
            )
            if reply == QtWidgets.QMessageBox.StandardButton.Yes:
                success = True
                errors = []
                # Remove each signature ID
                for face_id in face_ids:
                    res = subprocess.run(["pkexec", "howdy", "-y", "remove", face_id], capture_output=True, text=True)
                    if res.returncode != 0:
                        success = False
                        errors.append(res.stderr or f"Failed to remove ID {face_id}")
                        
                self.update_profiles()
                if success:
                    QtWidgets.QMessageBox.information(self, "Success", f"Profile '{lbl}' deleted successfully.")
                else:
                    QtWidgets.QMessageBox.critical(self, "Error", f"Failed to delete some signatures:\n" + "\n".join(errors))

        def add_profile(self):
            self.stop_preview()
            
            item = self.list_cameras.currentItem()
            dev_path = item.data(QtCore.Qt.ItemDataRole.UserRole) if item else "/dev/video0"
            
            default_name = os.environ.get("SUDO_USER") or os.environ.get("USER") or "default"
            label, ok = QtWidgets.QInputDialog.getText(
                self, "Profile Label", "Enter a label for this face model:", 
                QtWidgets.QLineEdit.EchoMode.Normal, default_name
            )
            if ok and label.strip():
                dialog = EnrollmentDialog(self, label.strip(), dev_path)
                dialog.exec()
                self.update_profiles()

        def improve_profile(self):
            item = self.list_profiles.currentItem()
            if not item:
                return
                
            label = item.data(QtCore.Qt.ItemDataRole.UserRole + 1)
            
            # Get currently selected camera path
            cam_item = self.list_cameras.currentItem()
            dev_path = cam_item.data(QtCore.Qt.ItemDataRole.UserRole) if cam_item else "/dev/video0"
            
            self.stop_preview()
            
            dialog = EnrollmentDialog(self, label, dev_path)
            dialog.exec()
            self.update_profiles()

        def on_profile_selection_changed(self, current, previous):
            has_selection = current is not None
            self.btn_improve.setEnabled(has_selection)
            self.btn_delete_profile.setEnabled(has_selection)

        def toggle_preview(self):
            if self.preview_thread and self.preview_thread.isRunning():
                self.stop_preview()
            else:
                item = self.list_cameras.currentItem()
                if not item:
                    QtWidgets.QMessageBox.warning(self, "Warning", "Please select a camera device from the list to test.")
                    return
                dev_path = item.data(QtCore.Qt.ItemDataRole.UserRole)
                self.start_preview(dev_path)

        def start_preview(self, dev_path):
            self.lbl_preview.setText("Initializing camera...")
            self.preview_thread = CameraThread(dev_path)
            self.preview_thread.change_pixmap_signal.connect(self.update_preview)
            self.preview_thread.start()
            self.btn_test_cam.setText("Stop Test")
            self.btn_test_cam.setObjectName("btn_danger")
            self.btn_test_cam.style().unpolish(self.btn_test_cam)
            self.btn_test_cam.style().polish(self.btn_test_cam)

        def stop_preview(self):
            if self.preview_thread:
                self.preview_thread.stop()
                self.preview_thread = None
            self.lbl_preview.setText("Camera Preview Inactive")
            self.lbl_preview.setPixmap(QtGui.QPixmap())
            self.btn_test_cam.setText("Test Selected Camera")
            self.btn_test_cam.setObjectName("")
            self.btn_test_cam.style().unpolish(self.btn_test_cam)
            self.btn_test_cam.style().polish(self.btn_test_cam)

        def update_preview(self, qimage):
            self.lbl_preview.setPixmap(QtGui.QPixmap.fromImage(qimage))

        def closeEvent(self, event):
            self.stop_preview()
            event.accept()

    app = QtWidgets.QApplication(sys.argv)
    
    # Set QApplication stylesheet to enforce uniform dark theme on dialogs and menus
