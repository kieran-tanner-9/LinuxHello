    class CameraThread(QtCore.QThread):
        change_pixmap_signal = QtCore.pyqtSignal(QtGui.QImage)
        
        def __init__(self, device_path):
            super().__init__()
            self.device_path = device_path
            self._run_flag = True
            
        def run(self):
            import cv2
            # Attempt to use the V4L2 backend on Linux
            cap = cv2.VideoCapture(self.device_path, cv2.CAP_V4L2)
            if not cap.isOpened():
                # Fallback backend
                cap = cv2.VideoCapture(self.device_path)
                
            time.sleep(0.5) # Warm up
            while self._run_flag:
                ret, frame = cap.read()
                if ret:
                    rgb_image = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
                    h, w, ch = rgb_image.shape
                    bytes_per_line = ch * w
                    convert_to_Qt_format = QtGui.QImage(rgb_image.data, w, h, bytes_per_line, QtGui.QImage.Format.Format_RGB888)
                    p = convert_to_Qt_format.scaled(480, 360, QtCore.Qt.AspectRatioMode.KeepAspectRatio)
                    self.change_pixmap_signal.emit(p)
                else:
                    time.sleep(0.03)
            cap.release()
            
        def stop(self):
            self._run_flag = False
            self.wait()
