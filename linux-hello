def print_help():
    print(f"""
{BOLD}{MAGENTA}Linux Hello Wrapper Tool - Windows Hello Face Auth for Linux{RESET}
Usage: {CYAN}sudo {sys.argv[0]} [command]{RESET}

Available Commands:
  {BOLD}status{RESET}             Show configuration, packages, camera list, and active state.
  {BOLD}install{RESET}            Add repository and install Howdy & dependencies.
  {BOLD}setup-camera{RESET}       Configure which camera path Howdy should use.
  {BOLD}test-camera{RESET}        Launch an interactive ASCII terminal test stream for a camera.
  {BOLD}enroll{RESET}             Scan your face and add a new face signature.
  {BOLD}enroll-and-verify{RESET}  Securely enroll face signature with mismatch checking. (requires root)
  {BOLD}enable-pam{RESET}         Safely configure PAM to enable facial login and sudo authentication.
  {BOLD}disable-pam{RESET}        Disable facial recognition and restore default PAM authentication.
  {BOLD}set-priority{RESET}       Save camera list in preferred order. (requires root)
  {BOLD}udev-trigger{RESET}       Update Howdy config to highest priority connected camera.
  {BOLD}enable-switching{RESET}   Install and enable dynamic switching udev & systemd service.
  {BOLD}disable-switching{RESET}  Remove dynamic switching rules and service.
  {BOLD}gui{RESET}                Open the graphical manager control panel.
  {BOLD}help{RESET}               Display this help message.
""")

def main():
    if len(sys.argv) < 2:
        print_help()
        sys.exit(0)
        
    cmd = sys.argv[1].lower()
    
    if cmd == "status":
        cmd_status()
    elif cmd == "install":
        cmd_install()
    elif cmd == "setup-camera":
        cmd_setup_camera()
    elif cmd == "test-camera":
        device_path = sys.argv[2] if len(sys.argv) > 2 else None
        cmd_test_camera(device_path)
    elif cmd == "enroll":
        cmd_enroll()
    elif cmd == "enroll-and-verify":
        if len(sys.argv) < 4:
            print(f"{RED}Error: enroll-and-verify requires user and label.{RESET}")
            print(f"Usage: {sys.argv[0]} enroll-and-verify [user] [label]")
            sys.exit(1)
        user = sys.argv[2]
        label = sys.argv[3]
        cmd_enroll_and_verify(user, label)
    elif cmd == "enable-pam":
        cmd_enable_pam()
    elif cmd == "disable-pam":
        cmd_disable_pam()
    elif cmd == "set-priority":
        devices = sys.argv[2:]
        cmd_set_priority(devices)
    elif cmd == "udev-trigger":
        cmd_udev_trigger()
    elif cmd == "enable-switching":
        cmd_enable_switching()
    elif cmd == "disable-switching":
        cmd_disable_switching()
    elif cmd == "gui":
        cmd_gui()
    elif cmd in ("help", "-h", "--help"):
        print_help()
    else:
        print(f"{RED}Unknown command: {cmd}{RESET}")
        print_help()
        sys.exit(1)

if __name__ == "__main__":
    main()

